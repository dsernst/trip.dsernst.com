{
  "name": "random-trip",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsc --noEmit && npm run lint",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=e2e/cache/.playwright-browsers playwright install chromium",
    "test:visual": "PLAYWRIGHT_BROWSERS_PATH=e2e/cache/.playwright-browsers playwright test --config e2e/playwright.config.ts",
    "test:visual:update": "PLAYWRIGHT_BROWSERS_PATH=e2e/cache/.playwright-browsers playwright test --config e2e/playwright.config.ts --update-snapshots"
  },
  "dependencies": {
    "libphonenumber-js": "^1.13.1",
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5"
  }
}
